{
  "name": "elbantams-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cd website && npm run dev",
    "build": "cd website && npm run build",
    "preview": "npx wrangler pages dev website/dist",
    "db:migrate:local": "npx wrangler d1 migrations apply elbantams-auth --local",
    "db:migrate:prod": "npx wrangler d1 migrations apply elbantams-auth --remote"
  },
  "dependencies": {
    "better-auth": "^1.5.6",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "wrangler": "^4.0.0"
  }
}
